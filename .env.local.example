# ── Clerk Auth ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Gemini (Google AI Studio) ──────────────────────────
GEMINI_API_KEY=AIzaSy...

# ── Google Calendar OAuth (optional but recommended) ───
# Setup: console.cloud.google.com → Enable Calendar API → OAuth 2.0
# Redirect URI: https://YOUR_DOMAIN/api/calendar/callback
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ── App URL (needed for OAuth redirect) ────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Change to your Vercel URL when deploying:
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
